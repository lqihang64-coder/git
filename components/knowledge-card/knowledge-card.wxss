/* 继承全局卡片基础样式，这里只写组件特有的 */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
}

.animate-fade-in { animation: fadeIn 0.4s ease-out; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }

/* Header */
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.card-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.category-tag {
  background: #EEF2FF; color: #4F46E5;
  font-size: 22rpx; font-weight: 800; padding: 8rpx 20rpx; border-radius: 12rpx;
}

/* 声音按钮与动画 */
.sound-btn { position: relative; width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center; }
.icon-sound { width: 32rpx; height: 32rpx; opacity: 0.6; transition: all 0.3s; }
.playing .icon-sound { opacity: 1; transform: scale(1.1); }

.sound-wave {
  position: absolute; width: 100%; height: 100%; border-radius: 50%;
  border: 2rpx solid #4F46E5; opacity: 0;
  animation: wave 1.5s infinite;
}
@keyframes wave {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(2); opacity: 0; }
}

/* Titles */
.title-group { margin-bottom: 30rpx; }
.card-title { font-size: 52rpx; font-weight: 900; color: #0F172A; display: block; margin-bottom: 8rpx; line-height: 1.2; letter-spacing: -1rpx; }
.card-subtitle { font-size: 30rpx; color: #64748B; font-weight: 500; letter-spacing: 1rpx; }

/* Content */
.card-content { font-size: 32rpx; color: #334155; line-height: 1.75; text-align: justify; display: block; margin-bottom: 40rpx; letter-spacing: 1rpx; }

/* AI Box */
.ai-box { background: #F8FAFC; border-radius: 16rpx; padding: 24rpx; border: 1rpx solid #F1F5F9; display: flex; gap: 20rpx; }
.ai-line { width: 6rpx; background: #4F46E5; border-radius: 4rpx; }
.ai-label { display: block; font-size: 24rpx; font-weight: 700; color: #4F46E5; margin-bottom: 8rpx; }
.ai-content { font-size: 28rpx; color: #334155; line-height: 1.6; }