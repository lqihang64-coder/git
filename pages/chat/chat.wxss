/* 页面背景 */
page {
  background-color: #F1F5F9; /* 浅灰背景 */
  height: 100vh;
  overflow: hidden; /* 禁止页面整体滚动，只让 scroll-view 滚 */
}

.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 🟢 新增：顶部工具栏微调脉冲动画 */
@keyframes pulse {
  0% { transform: scale(0.95); opacity: 0.5; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
  70% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 10rpx rgba(16, 185, 129, 0); }
  100% { transform: scale(0.95); opacity: 0.5; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
}

/* 消息列表 */
.chat-list {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
  height: 0; /* 关键：让 flex:1 生效 */
}

/* 消息行 */
.msg-row {
  display: flex;
  margin-bottom: 40rpx;
  align-items: flex-start;
}

/* 用户消息靠右 */
.msg-row.user {
  justify-content: flex-end;
}

/* AI 消息靠左 */
.msg-row.ai {
  justify-content: flex-start;
}

/* 头像通用样式 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background-color: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  margin-right: 20rpx;
}

.user-avatar {
  background-color: #CBD5E1;
  margin-left: 20rpx;
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

/* 气泡通用样式 */
.msg-bubble {
  max-width: 70%;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  position: relative;
  word-wrap: break-word; /* 防止长单词溢出 */
}

/* AI 气泡样式 (白底黑字) */
.ai .msg-bubble {
  background-color: #FFFFFF;
  color: #1E293B;
  border-top-left-radius: 4rpx; /* 左上角直角，指向头像 */
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 用户气泡样式 (蓝底白字) */
.user .msg-bubble {
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
  color: #FFFFFF;
  border-top-right-radius: 4rpx; /* 右上角直角，指向头像 */
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.2);
}

/* --- 底部输入区 --- */
.input-area {
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); /* 适配 iPhone 底部黑条 */
  border-top: 1rpx solid #F1F5F9;
}

.input-box {
  background-color: #F8FAFC;
  border-radius: 40rpx;
  padding: 10rpx 10rpx 10rpx 30rpx; /* 右侧留给按钮 */
  display: flex;
  align-items: center;
  border: 1rpx solid #E2E8F0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #0F172A;
}

.btn-send {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-send.active {
  background-color: #4F46E5; /* 激活时变蓝 */
  transform: scale(1.05);
}

.icon-send {
  color: #FFFFFF;
  font-weight: bold;
  font-size: 32rpx;
  padding-bottom: 4rpx; /* 微调箭头位置 */
}

/* --- Loading 动画 (三个跳动的点) --- */
.loading-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 30rpx 40rpx; /* 稍微大一点 */
  background-color: #FFF !important;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #94A3B8;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}