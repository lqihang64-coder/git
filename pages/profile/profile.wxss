/* ==========================================================================
   1. 页面基础与全域布局
   ========================================================================== */
   page {
    background-color: #F8FAFC;
    padding-bottom: 40rpx;
  }
  
  .container {
    min-height: 100vh;
  }
  
  /* --- 滚动容器 --- */
  .content-scroll {
    width: 100%;
    height: 100vh;
  }
  
  /* ==========================================================================
     2. 头部区域 (沉浸式卡片与悬浮头像)
     ========================================================================== */
  .profile-header {
    background: #FFFFFF;
    position: relative;
    overflow: hidden;
    padding-bottom: 50rpx;
    border-radius: 0 0 48rpx 48rpx;
    box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.1);
    margin-bottom: 40rpx;
  }
  
  /* 顶部背景装饰 */
  .header-bg {
    height: 220rpx;
    background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
    position: relative;
  }
  .header-bg::after {
    content: '';
    position: absolute;
    top: -50%; right: -20%;
    width: 400rpx; height: 400rpx;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.1) 0%, transparent 70%);
    border-radius: 50%;
  }
  
  .profile-info {
    margin-top: -100rpx; /* 头像半悬浮效果 */
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 10;
  }
  
  /* 头像容器组件 */
  .avatar-wrapper {
    padding: 0 !important;
    width: 180rpx !important;
    height: 180rpx !important;
    border-radius: 50% !important;
    margin-bottom: 24rpx !important;
    background: #FFF !important;
    position: relative !important;
    box-shadow: 0 12rpx 32rpx rgba(79, 70, 229, 0.2);
    border: 8rpx solid #FFF !important;
    transition: transform 0.3s;
  }
  .avatar-wrapper:active { transform: scale(0.96); }
  .avatar-wrapper::after { border: none !important; }
  .avatar { width: 100%; height: 100%; border-radius: 50%; display: block; }
  
  /* 摄像机图标微章 */
  .edit-badge {
    position: absolute; bottom: 6rpx; right: 6rpx;
    width: 56rpx; height: 56rpx;
    background: #4F46E5;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    border: 4rpx solid #FFF;
    box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2);
    z-index: 2;
  }
  .camera-icon-css {
    width: 24rpx;
    height: 18rpx;
    background: #FFF; border-radius: 2rpx;
    position: relative;
  }
  .camera-icon-css::before {
    content: ''; position: absolute; top: -4rpx; left: 50%;
    transform: translateX(-50%);
    width: 8rpx; height: 4rpx; background: #FFF; border-radius: 2rpx 2rpx 0 0;
  }
  .camera-icon-css::after {
    content: ''; position: absolute;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 8rpx; height: 8rpx; border: 2rpx solid #4F46E5; border-radius: 50%;
  }
  
  /* 微信昵称输入框 */
  .nickname-input {
    font-size: 36rpx; font-weight: 800; color: #1E293B;
    margin-bottom: 16rpx; text-align: center; height: 50rpx; min-width: 300rpx;
  }
  
  /* 等级徽章 */
  .level-badge { 
    background: rgba(30, 41, 59, 0.9); 
    color: #F1F5F9; 
    font-size: 20rpx; 
    padding: 6rpx 20rpx; 
    border-radius: 20rpx;
    font-weight: 600; 
    letter-spacing: 1rpx;
    display: flex; align-items: center; gap: 6rpx;
  }
  
  /* 数据网格看板 */
  .stats-card {
    margin: 40rpx 30rpx 0;
    background: #F8FAFC;
    border-radius: 24rpx;
    padding: 24rpx 0;
    display: flex;
    justify-content: space-around;
    width: 90%;
  }
  .stat-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
  .stat-num { font-size: 36rpx; font-weight: 800; color: #0F172A; line-height: 1.2; }
  .stat-label { font-size: 22rpx; color: #64748B; margin-top: 8rpx; }
  .stat-divider { width: 2rpx; background: #E2E8F0; height: 40rpx; align-self: center; }
  
  /* ==========================================================================
     3. 通用板块卡片 (我的兴趣与学习足迹)
     ========================================================================== */
  .section-card { 
    margin: 0 32rpx 32rpx; 
    background: #FFF;
    border-radius: 32rpx;
    padding: 32rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
  }
  
  .section-header { 
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx;
  }
  .section-title { 
    font-size: 30rpx; font-weight: 800; color: #1E293B; 
    display: flex; align-items: center; gap: 12rpx;
  }
  .section-title::before {
    content: ''; width: 8rpx; height: 28rpx; background: #4F46E5; border-radius: 4rpx;
  }
  
  /* --- 主页兴趣展示标签行 --- */
  .icon-plus { 
    width: 52rpx; height: 52rpx; 
    background: #F1F5F9; color: #64748B; 
    border-radius: 50%; 
    text-align: center;
    line-height: 48rpx; 
    font-size: 40rpx; font-weight: 300;
  }
  .btn-hover { opacity: 0.7; background: #E2E8F0; }
  
  .tags-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
  .tag-item { 
    background: #EEF2FF;
    color: #4F46E5; 
    font-size: 26rpx; font-weight: 600; 
    padding: 12rpx 24rpx; 
    border-radius: 40rpx;
    border: 1rpx solid transparent;
    display: inline-flex; align-items: center;
  }
  
  /* --- 学习足迹时间轴 (Timeline) --- */
  .timeline-container { padding-left: 10rpx; }
  .timeline-item { display: flex; position: relative; padding-bottom: 40rpx; }
  .timeline-item:last-child { padding-bottom: 0; }
  
  .timeline-line {
    position: absolute;
    left: 20rpx; top: 24rpx; bottom: 0;
    width: 2rpx; background: #E2E8F0;
    z-index: 0;
  }
  .timeline-item:last-child .timeline-line { display: none; }
  
  .timeline-dot {
    width: 16rpx; height: 16rpx;
    background: #FFF;
    border: 4rpx solid #4F46E5;
    border-radius: 50%;
    margin-right: 30rpx;
    margin-top: 10rpx;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    left: 10rpx;
  }
  
  .timeline-content {
    flex: 1;
    background: #F8FAFC;
    padding: 20rpx 24rpx;
    border-radius: 16rpx;
  }
  .timeline-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 8rpx;
  }
  .timeline-title { font-size: 28rpx; font-weight: 700; color: #1E293B; }
  .timeline-time { font-size: 22rpx; color: #94A3B8; font-weight: 500; white-space: nowrap; margin-left: 20rpx; }
  .timeline-desc { font-size: 24rpx; color: #64748B; }
  
  .empty-tip { text-align: center; color: #94A3B8; font-size: 26rpx; padding: 40rpx 0; font-style: italic; }
  
  /* --- 通用设置菜单列表 --- */
  .settings-list { padding: 0 32rpx; }
  .setting-item { 
    display: flex; justify-content: space-between; align-items: center;
    padding: 32rpx 0;
    border-bottom: 1rpx solid #F1F5F9;
  }
  .setting-item:last-child { border-bottom: none; }
  .setting-left { display: flex; align-items: center; gap: 20rpx; font-size: 28rpx; font-weight: 600; color: #334155; }
  .arrow { color: #CBD5E1; font-size: 24rpx; }
  
  
  /* ==========================================================================
     4. 半屏弹窗样式 (Bottom Sheet) 
     ========================================================================== */
  .tag-sheet-overlay {
    position: fixed; inset: 0; z-index: 999;
    display: flex; flex-direction: column; justify-content: flex-end;
    pointer-events: none;
  }
  .tag-sheet-overlay.show { pointer-events: auto; }
  
  /* 毛玻璃半透明护罩 */
  .tag-sheet-backdrop {
    position: absolute; inset: 0;
    background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4rpx);
    opacity: 0; transition: opacity 0.3s ease;
  }
  .tag-sheet-overlay.show .tag-sheet-backdrop { opacity: 1; }
  
  /* 弹窗抽屉主体 */
  .tag-sheet-content {
    background: #FFFFFF;
    border-radius: 40rpx 40rpx 0 0;
    padding: 30rpx 40rpx 60rpx;
    position: relative; z-index: 1000;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    max-height: 80vh; display: flex; flex-direction: column;
  }
  .tag-sheet-overlay.show .tag-sheet-content { transform: translateY(0); }
  
  .sheet-handle {
    width: 80rpx; height: 10rpx; background: #E2E8F0;
    border-radius: 10rpx; margin: 0 auto 40rpx;
  }
  
  .sheet-header { margin-bottom: 40rpx; text-align: center; }
  .sheet-title { font-size: 36rpx; font-weight: 800; color: #0F172A; display: block; margin-bottom: 8rpx;}
  .sheet-subtitle { font-size: 26rpx; color: #64748B; font-weight: 500; }
  
  .sheet-scroll { max-height: 50vh; }
  .sheet-tags-container { display: flex; flex-wrap: wrap; gap: 24rpx; padding-bottom: 20rpx; }
  
  /* --------------------------------------------------------------------------
     弹窗内部纯文字标签样式 (透明灰框 -> 静止科技蓝)
     -------------------------------------------------------------------------- */
  
  /* 未选中默认状态 */
  .sheet-tags-container .sheet-tag {
    background-color: transparent !important;
    border: 3rpx solid #E2E8F0 !important;
    color: #475569 !important;
    font-size: 28rpx;
    font-weight: 600;
    padding: 18rpx 40rpx !important;
    border-radius: 60rpx !important;
    display: flex; align-items: center; justify-content: center;
    box-sizing: border-box;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  
  /* 🟢 激活变蓝态（已彻底去掉了震动和缩放动画，变色时整体保持平静） */
  .sheet-tags-container .sheet-tag.active {
    background-color: #EEF2FF !important;
    border-color: #4F46E5 !important;
    color: #4F46E5 !important;
    font-weight: 700;
    box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.15) !important;
    transform: scale(1) !important; /* 强制保持原大 */
  }
  
  /* 手指长按点击时的微小内缩手感，松开手瞬间回弹为 1.0 的平滑无碎步效果 */
  .sheet-tags-container .sheet-tag:active {
    opacity: 0.75;
    transform: scale(0.94);
  }
  
  /* 底部选好了按钮 */
  .sheet-footer { margin-top: 40rpx; }
  .btn-confirm {
    background: #0F172A; color: #FFF; border-radius: 60rpx;
    height: 96rpx; display: flex; align-items: center; justify-content: center;
    font-size: 32rpx; font-weight: 700; box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.2);
  }
  .btn-confirm:active { transform: scale(0.98); opacity: 0.9; }