/* ==========================================================================
   1. 页面基础及防溢出约束
   ========================================================================== */
   page {
    background-color: #F8FAFC; /* 现代 Slate 浅色底 */
    padding-bottom: 60rpx;
  }
  
  .history-page {
    box-sizing: border-box;
    width: 100%;
    overflow-x: hidden;
  }
  
  /* ==========================================================================
     2. 顶部 Banner 区域（现代微渐变）
     ========================================================================== */
  .history-banner {
    padding: 50rpx 40rpx 40rpx;
    position: relative;
    overflow: hidden;
  }
  
  .banner-glow {
    position: absolute;
    top: -100rpx;
    left: -50rpx;
    width: 400rpx;
    height: 400rpx;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, rgba(255, 255, 255, 0) 70%);
    z-index: 1;
  }
  
  .banner-title {
    font-size: 46rpx;
    font-weight: 900;
    color: #0F172A;
    display: block;
    letter-spacing: 2rpx;
    position: relative;
    z-index: 2;
  }
  
  .banner-subtitle {
    font-size: 24rpx;
    color: #64748B;
    margin-top: 10rpx;
    display: block;
    font-weight: 500;
    position: relative;
    z-index: 2;
  }
  
  /* ==========================================================================
     3. 核心时光骨架轴线
     ========================================================================== */
  .timeline-container {
    position: relative;
    padding: 10rpx 30rpx;
  }
  
  /* 中央纵深流动线 */
  .timeline-main-line {
    position: absolute;
    top: 30rpx;
    bottom: 30rpx;
    left: 68rpx; /* 与左侧定位精准对齐 */
    width: 4rpx;
    background: linear-gradient(to bottom, #E2E8F0 0%, #E2E8F0 80%, rgba(226, 232, 240, 0) 100%);
    z-index: 1;
  }
  
  /* 行容器布局隔离 */
  .timeline-row {
    display: flex;
    position: relative;
    z-index: 5;
    margin-bottom: 36rpx;
    width: 100%;
    box-sizing: border-box;
    transition: all 0.2s ease-out;
  }
  
  /* 左轴定位列 */
  .timeline-left-axis {
    width: 80rpx;
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 36rpx; /* 对应右侧卡片头部线 */
    position: relative;
  }
  
  /* 渐变流光轴点 */
  .timeline-glow-dot {
    width: 16rpx;
    height: 16rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366F1, #4F46E5);
    border: 5rpx solid #FFFFFF;
    box-shadow: 0 0 0 6rpx rgba(79, 70, 229, 0.2);
    z-index: 10;
  }
  
  /* ==========================================================================
     4. 旗舰级悬浮内容卡片（防文字错位核心）
     ========================================================================== */
  .history-premium-card {
    flex: 1;
    background: #FFFFFF;
    border-radius: 24rpx;
    padding: 32rpx;
    box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
    border: 1rpx solid #E2E8F0;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden; /* 强力防内容冲破卡片边界 */
  }
  
  /* 卡片反馈呼吸态 */
  .card-hover-active {
    transform: translateY(-2rpx);
  }
  .card-hover-active .history-premium-card {
    border-color: #CBD5E1;
    box-shadow: 0 8rpx 24rpx rgba(148, 163, 184, 0.1);
    background-color: #FAFAFA;
  }
  
  /* 元数据栏 */
  .card-meta-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
    width: 100%;
  }
  
  .card-timestamp {
    font-size: 24rpx;
    color: #94A3B8;
    font-weight: 600;
  }
  
  /* 悬浮复习胶囊 */
  .review-pill-badge {
    background: #EEF2FF;
    padding: 6rpx 20rpx;
    border-radius: 30rpx;
    display: flex;
    align-items: center;
  }
  .badge-text {
    font-size: 22rpx;
    color: #4F46E5;
    font-weight: bold;
  }
  .badge-arrow {
    font-size: 22rpx;
    color: #4F46E5;
    margin-left: 6rpx;
    font-weight: bold;
  }
  
  /* 标题承载区（解决文字粗糙与死扣排版） */
  .card-title-content {
    width: 100%;
    box-sizing: border-box;
    margin-bottom: 16rpx;
  }
  
  .card-main-title {
    font-size: 30rpx;
    color: #1E293B;
    font-weight: bold;
    line-height: 1.5;
    display: block;
    word-wrap: break-word; /* 强力防长英文/复杂标题撑死破位 */
    word-break: break-all;
  }
  
  /* 底部引导装饰流 */
  .card-footer-tip {
    display: flex;
    align-items: center;
    border-top: 1rpx solid #F1F5F9;
    padding-top: 16rpx;
    margin-top: 4rpx;
  }
  .tip-spark {
    font-size: 24rpx;
    margin-right: 8rpx;
  }
  .tip-text {
    font-size: 24rpx;
    color: #64748B;
    font-weight: 500;
  }
  
  /* ==========================================================================
     5. 空状态极简排版
     ========================================================================== */
  .history-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-top: 200rpx;
    box-sizing: border-box;
  }
  
  .empty-icon-box {
    font-size: 100rpx;
    margin-bottom: 30rpx;
    opacity: 0.8;
  }
  
  .empty-main-text {
    font-size: 30rpx;
    color: #94A3B8;
    font-weight: bold;
    display: block;
  }
  
  .empty-sub-text {
    font-size: 24rpx;
    color: #CBD5E1;
    margin-top: 8rpx;
    display: block;
    font-weight: 500;
  }